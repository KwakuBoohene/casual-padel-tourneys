{
  "name": "casual-padel-tourneys",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web,mobile -c cyan,magenta,yellow \"npm run dev --workspace @padel/api\" \"npm run dev --workspace @padel/web\" \"npm run dev --workspace @padel/mobile\"",
    "dev:core": "concurrently -n api,web -c cyan,magenta \"npm run dev --workspace @padel/api\" \"npm run dev --workspace @padel/web\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "simulate": "npm run simulate --workspace @padel/api",
    "db:generate": "npm run db:generate --workspace @padel/api",
    "db:migrate": "npm run db:migrate --workspace @padel/api"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@types/react": "~19.1.10",
    "dotenv": "^17.3.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  }
}
