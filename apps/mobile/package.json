{
  "name": "@padel/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "build": "echo \"Use EAS build in production\"",
    "build:ios": "eas build --platform ios --profile preview",
    "build:android": "eas build --platform android --profile preview",
    "build:web": "eas build --platform web --profile preview",
    "export:web": "expo export --platform web",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@padel/shared": "*",
    "expo": "^54.0.17",
    "expo-auth-session": "~5.5.1",
    "expo-secure-store": "~13.0.2",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-native": "^0.81.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10"
  }
}
