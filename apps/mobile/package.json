{
  "name": "@padel/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "build": "echo \"Use EAS build in production\"",
    "build:ios": "eas build --platform ios --profile preview",
    "build:android": "eas build --platform android --profile preview",
    "build:web": "eas build --platform web --profile preview",
    "export:web": "expo export --platform web",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "55.0.11",
    "@padel/shared": "*",
    "expo": "55.0.24",
    "expo-auth-session": "55.0.16",
    "expo-secure-store": "55.0.14",
    "expo-web-browser": "55.0.16",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.85.3",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "@types/react": "19.2.14"
  }
}
